{
  "name": "markdown-it",
  "version": "14.2.0",
  "description": "Markdown-it - modern pluggable markdown parser.",
  "keywords": [
    "markdown",
    "parser",
    "commonmark",
    "markdown-it",
    "markdown-it-plugin"
  ],
  "type": "module",
  "repository": "markdown-it/markdown-it",
  "license": "MIT",
  "main": "dist/markdown-it.cjs",
  "types": "dist/index.d.mts",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/puzrin"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/markdown-it"
    }
  ],
  "module": "index.mjs",
  "exports": {
    ".": {
      "require": {
        "default": "./dist/index.cjs",
        "types": "./dist/index.d.mts"
      },
      "import": {
        "default": "./index.mjs",
        "types": "./dist/index.d.mts"
      }
    },
    "./token": {
      "require": {
        "default": "./dist/token.cjs",
        "types": "./dist/token.d.mts"
      },
      "import": {
        "default": "./dist/token.mjs",
        "types": "./dist/token.d.mts"
      }
    },
    "./lib/token": {
      "require": {
        "default": "./dist/token.cjs",
        "types": "./dist/token.d.mts"
      },
      "import": {
        "default": "./dist/token.mjs",
        "types": "./dist/token.d.mts"
      }
    },
    "./*": {
      "require": "./dist/*",
      "import": "./*",
      "types": "./dist/*"
    }
  },
  "bin": "bin/markdown-it.mjs",
  "scripts": {
    "lint": "eslint .",
    "test": "npm run lint && npm run test:cmspec && npm run test:markdown-it && npm run test:build",
    "test:cmspec": "node --test --test-reporter=dot test/cmspec/**/*.test.mjs",
    "test:markdown-it": "node --test test/markdown-it/**/*.test.mjs",
    "test:build": "npm run build && node --test test/build/**/*.test.mjs",
    "pathological:track-ref": "node support/track-ref-pathological.mjs",
    "pathological:update-hash": "node support/track-ref-pathological.mjs --update",
    "coverage": "npm run build && c8 --include 'lib/**' -r text -r html -r lcov node --test --test-reporter=dot",
    "doc": "node support/build_doc.mjs",
    "gh-doc": "npm run doc && gh-pages -d apidoc -f",
    "demo": "npm run lint && node support/build_demo.mjs",
    "gh-demo": "npm run demo && gh-pages -d demo -f -b master -r git@github.com:markdown-it/markdown-it.github.io.git",
    "build:default": "rollup -c support/rollup.config.mjs",
    "build:pack": "node packer.cjs --yarn",
    "build:tsc": "tsc -b tsconfig.docs.json",
    "build": "rimraf dist && node support/build-dist.mjs && rollup -c && npm run build:tsc && npm run build:pack",
    "specsplit": "support/specsplit.mjs good -o test/fixtures/commonmark/good.txt && support/specsplit.mjs bad -o test/fixtures/commonmark/bad.txt && support/specsplit.mjs",
    "prepublishOnly": "npm test && npm run build && npm run gh-demo && npm run gh-doc",
    "update:packer": "curl -L https://github.com/dimaslanjaka/nodejs-package-types/raw/main/packer.js > packer.cjs",
    "clean": "npx rimraf dist tmp",
    "benchmark-deps": "npm install --prefix benchmark/extra/",
    "todo": "grep 'TODO' -n -r ./lib 2>/dev/null",
    "prepack": "npm test && npm run build && npm run demo && npm run doc",
    "postpublish": "npm run gh-demo && npm run gh-doc"
  },
  "files": [
    "index.mjs",
    "lib/",
    "dist/"
  ],
  "dependencies": {
    "ansi-colors": "^4.1.3",
    "argparse": "^2.0.1",
    "entities": "^4.5.0",
    "linkify-it": "^5.0.1",
    "mdurl": "^2.0.0",
    "minimist": "^1.2.8",
    "punycode.js": "^2.3.1",
    "uc.micro": "^2.1.0",
    "upath": "^2.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.7",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.12.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/babel__core": "^7",
    "@types/fs-extra": "^11.0.4",
    "@types/minimist": "^1",
    "ansi": "^0.3.0",
    "benchmark": "~2.1.0",
    "binary-collections": "^2.0.9",
    "c8": "^11.0.0",
    "chai": "^4.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.11.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-promise": "^7.1.0",
    "express": "^4.14.0",
    "gh-pages": "^6.3.0",
    "git-command-helper": "^2.0.2",
    "globals": "^15.11.0",
    "highlight.js": "^11.11.1",
    "jest-worker": "^29.7.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.1",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-for-inline": "^2.0.1",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "ndoc": "^6.0.1",
    "neostandard": "^0.13.0",
    "terser": "^5.48.0",
    "tinybench": "^6.0.2",
    "vite": "^8.0.14",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "packageManager": "yarn@4.13.0"
}
